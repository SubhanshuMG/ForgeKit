        { "src": "serverless.yml.hbs", "dest": "serverless.yml" },
        { "src": "README.md.hbs", "dest": "README.md" },
        { "src": "gitignore", "dest": ".gitignore" },
        { "src": ".env.example", "dest": ".env.example" },
        { "src": "src/handlers/health.ts", "dest": "src/handlers/health.ts" },
        { "src": "src/handlers/hello.ts", "dest": "src/handlers/hello.ts" },
        { "src": "src/__tests__/hello.test.ts", "dest": "src/__tests__/hello.test.ts" }
      ],
      "hooks": [
        { "type": "post-scaffold", "command": "npm", "args": ["install"] }
      ],
      "variables": [
        { "name": "name", "prompt": "Project name", "type": "string", "default": "my-serverless" }
      ]
    }
  ]
}
